# Epoch allocator (smallocator) API base URL.
# Used for chain config (/health) and SDK API calls.
VITE_API_BASE_URL=http://localhost:3000

# Master seed for the Miden testnet faucets (faucet ids + signing keys derive
# from it deterministically). Any string — hashed to 32 bytes by the SDK.
# TESTNET ONLY: this is inlined into the public bundle, so it is NOT secret.
# Never reuse it on mainnet or for any account holding value.
VITE_MIDEN_FAUCET_SEED=epoch-dashboard-miden-testnet-faucets-v1

# Optional Miden RPC endpoint used by the Reclaim page to look up notes and the
# current block height. Defaults to the public testnet endpoint when unset.
# VITE_MIDEN_RPC_URL=https://rpc.testnet.miden.io
